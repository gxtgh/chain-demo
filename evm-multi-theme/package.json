{
  "name": "evm-multi-theme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "seo:generate": "node ./scripts/generate-seo-files.mjs",
    "prerender:ssr": "vite build --ssr src/prerender/entry-server.tsx --outDir .prerender",
    "prerender:pages": "node ./scripts/prerender-pages.mjs",
    "build": "npm run seo:generate && tsc -b && vite build && npm run prerender:ssr && npm run prerender:pages",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@reown/appkit-wallet-button": "^1.8.19",
    "@tanstack/react-query": "^5.90.5",
    "antd": "^6.3.5",
    "ethers": "^6.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "sass": "^1.89.2",
    "viem": "^2.38.0",
    "wagmi": "^2.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.1"
  }
}
