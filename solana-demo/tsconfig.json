{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": [
    "app",
    "components",
    "hooks",
    "lib",
    "store",
    "types",
    "App.tsx",
    "main.tsx",
    "vite-env.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

